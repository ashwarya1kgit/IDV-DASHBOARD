# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# MONGODB_URI: Optional. Connection string for your MongoDB.
MONGODB_URI="mongodb://localhost:27017/idv-dashboard"

# SMTP_HOST / SMTP_USER / SMTP_PASS: Optional. Credentials for email reports.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="noreply@idv-dashboard.com"
